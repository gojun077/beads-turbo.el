#!/usr/bin/env bash
# elisp-test: run ERT tests for beads.el.
# Runs emacs --batch -Q in isolation. Safe for CI.
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"

test_files=$(find "$ROOT/test" -name "*-test.el" | sort)

if [ -z "$test_files" ]; then
    echo "No test files found"
    exit 0
fi

count=$(echo "$test_files" | wc -l)
echo "Running $count test file(s)..."
echo

# Portable mktemp across GNU (Linux) and BSD (macOS).
# GNU's `--suffix=.el` is not supported by BSD mktemp, so create a base
# tempfile with the standard XXXXXX template and add the `.el` suffix
# ourselves.
tmpbase=$(mktemp -t beads-elisp-test.XXXXXX)
tmpfile="${tmpbase}.el"
mv "$tmpbase" "$tmpfile"
trap 'rm -f "$tmpfile"' EXIT

{
  echo "(require 'ert)"
  for tf in $test_files; do
    echo "(load-file \"$tf\")"
  done
  echo
  echo "(ert-run-tests-batch-and-exit)"
} >"$tmpfile"

rc=0
emacs -Q --batch \
    -L "$ROOT" \
    -L "$ROOT/lisp" \
    -L "$ROOT/test" \
    -L "$ROOT/vendor/vui.el" \
    -L "$ROOT/vendor/mysql.el" \
    -l "$tmpfile" 2>&1 || rc=$?

echo
if [ "$rc" -eq 0 ]; then
    echo "✓ All tests passed"
else
    echo "✗ Some tests failed"
fi
exit "$rc"
